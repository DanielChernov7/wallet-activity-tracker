{
  "name": "wallet-activity-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade multi-chain wallet monitoring with enrichment, alerting and real-time API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:bot": "tsx watch src/bot/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/worker.js",
    "start:bot": "node dist/bot/index.js",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seeds/addressLabels.ts",
    "db:seed": "tsx prisma/seeds/addressLabels.ts",
    "pretest": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "worker": "tsx src/worker.ts",
    "api": "tsx src/api/server.ts",
    "bot": "tsx src/bot/index.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "10.2.1",
    "@fastify/websocket": "11.0.1",
    "@prisma/client": "5.22.0",
    "@solana/web3.js": "1.95.4",
    "@triton-one/yellowstone-grpc": "1.3.0",
    "bs58": "6.0.0",
    "bullmq": "5.34.0",
    "dotenv": "16.4.5",
    "ethers": "6.13.4",
    "fastify": "5.1.0",
    "ioredis": "5.4.1",
    "pino": "9.5.0",
    "prom-client": "15.1.3",
    "pino-pretty": "13.0.0",
    "telegraf": "4.16.3",
    "undici": "6.21.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.10.1",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.5",
    "testcontainers": "10.13.2",
    "@testcontainers/postgresql": "10.13.2",
    "@testcontainers/redis": "10.13.2"
  },
  "engines": {
    "node": ">=22"
  }
}
