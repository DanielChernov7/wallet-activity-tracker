# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wallet_tracker?schema=public"
# Used by docker-compose to provision Postgres (defaults match DATABASE_URL above)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wallet_tracker

# ── Redis / BullMQ ────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── EVM RPC endpoints (WebSocket; HTTPS fallback used by Multicall calls) ──
ETH_WSS_URL="wss://mainnet.infura.io/ws/v3/YOUR_KEY"
ETH_HTTP_URL="https://mainnet.infura.io/v3/YOUR_KEY"
BASE_WSS_URL=""
BASE_HTTP_URL=""
ARBITRUM_WSS_URL=""
ARBITRUM_HTTP_URL=""

# ── Solana ────────────────────────────────────────────────────────────────
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
YELLOWSTONE_GRPC_URL=""
YELLOWSTONE_GRPC_TOKEN=""

# ── Pricing providers ─────────────────────────────────────────────────────
COINGECKO_API_KEY=""
JUPITER_PRICE_URL="https://price.jup.ag/v6/price"

# ── Telegram bot ──────────────────────────────────────────────────────────
# Bot token from @BotFather. Required for /watch /unwatch /alerts /status.
TELEGRAM_BOT_TOKEN=""
# Optional fallback chat for system-level (non-user-bound) alerts.
TELEGRAM_CHAT_ID=""
# Comma-separated Telegram user IDs allowed to use the bot. Empty = open.
TELEGRAM_ALLOWED_USER_IDS=""

# ── HTTP API ──────────────────────────────────────────────────────────────
API_PORT=3000
LOG_LEVEL="info"

# ── Feature flags ─────────────────────────────────────────────────────────
# Opt-in ERC20 metadata cache (Redis + Multicall3 + CoinGecko fallback).
# Off by default so existing integration tests keep their behaviour.
ERC20_CACHE_ENABLED=false
# Multicall3 deployment (same address on most EVM chains).
MULTICALL3_ADDRESS="0xcA11bde05977b3631167028862bE2a173976CA11"
